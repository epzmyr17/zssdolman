<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:u="sap.ui.unified" xmlns:l="sap.ui.layout">
	<l:VerticalLayout width="100%">
		<!-- {path: 'viewModel>/TransactionType', formatter: '.formatter.formatBulkRequestTitle'} -->
		<Title text="{i18n>DownloadTemplate}" class="dtd-bold-title sapUiTinyMarginBottom"/>
		<Text text="{i18n>DownloadTemplateInfo} {i18n>BulkTransactRequest}" class="sapUiTinyMarginBottom sapUiTinyMarginBegin"/>
		<Button icon="sap-icon://download" type="Transparent" press="onDownloadTemplateNonTradeDoc" text="{i18n>BulkTemplateNonTradeDoc}"/>
		<Button icon="sap-icon://download" type="Transparent" press="onDownloadTemplateTrade" text="{i18n>BulkTemplateTrade}"/>
	</l:VerticalLayout>
</core:FragmentDefinition>