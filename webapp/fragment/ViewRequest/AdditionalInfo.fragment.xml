<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout">
	<l:VerticalLayout width="100%">
		<Title text="{i18n>AdditionalInfoTtl}" class="dtd-bold-title sapUiMediumMarginBottom"/>
		<l:BlockLayout class="dtd-customPanel sapUiSmallMarginBottom">
			<l:BlockLayoutRow>
				<l:BlockLayoutCell width="50%">
					<VBox>
						<Title text="{i18n>FileUpload}" class="dtd-blue-title dtd-bold-title"/>
						<List id="idAttachmentList" noDataText="{i18n>NoFileFound}" items="{path: 'NAV_OLHeader_Attachment', templateShareable: false}"
							class="sapUiSmallMarginBottom">
							<headerToolbar>
								<OverflowToolbar>
									<Text text="{path: 'viewOLRequest>/NAV_OLHeader_Attachment', formatter: '.formatter.formatAttachemntCount'}"/>
								</OverflowToolbar>
							</headerToolbar>
							<items>
								<CustomListItem>
									<HBox width="100%">
										<core:Icon size="2rem" src="{path: 'Icon'}"
											class="sapMUCItemIcon sapUiSmallMarginBegin sapUiSmallMarginTopBottom"/>
										<VBox class="sapUiSmallMarginBegin sapUiSmallMarginTopBottom" width="100%">
											<Link text="{FileName}" wrapping="true" width="90%" press="onOpenAttachment"/>
											<Label text="{i18n>fileSize} {path: 'FileSize', formatter: '.formatter.fnFormatBytes'}"/>
										</VBox>
									</HBox>
								</CustomListItem>
							</items>
						</List>
					</VBox>
				</l:BlockLayoutCell>
				<l:BlockLayoutCell width="50%">
					<VBox>
						<Title text="{i18n>SpecialInstructions}" class="dtd-blue-title dtd-bold-title sapUiSmallMarginBottom"/>
						<Text text="{Instructions}" wrapping="true"/>
					</VBox>
				</l:BlockLayoutCell>
			</l:BlockLayoutRow>
		</l:BlockLayout>
	</l:VerticalLayout>
</core:FragmentDefinition>