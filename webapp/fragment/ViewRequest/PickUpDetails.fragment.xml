<core:FragmentDefinition xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified" xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
	<VBox class="sapUiContentPadding dtd-customPanel sapUiMediumMarginBottom">
		<f:Form editable="false" class="dtd-form">
			<f:layout>
				<f:ResponsiveGridLayout labelSpanXL="5" labelSpanL="5" labelSpanM="4" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"
					emptySpanM="0" emptySpanS="0" columnsXL="3" columnsL="2" columnsM="2" singleContainerFullSize="false"/>
			</f:layout>
			<f:formContainers>
				<!--Pickup Details-->
				<f:FormContainer title="{i18n>PickUpTtl}">
					<f:formElements>
						<f:FormElement label="{i18n>PickUpLocationLbl}">
							<Text text="{viewOLRequest>/NAV_OLHeader_Item/0/PickupOriginDesc}"/>
						</f:FormElement>
						<!--Address Details if origin is from O, warehouse, supplier & e waste-->
						<f:FormElement label="{i18n>AdressLbl}"
							visible="{= (${viewOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'O' || (${viewOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} !== 'G' &amp;&amp; ${viewOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} !== '')) &amp;&amp; ${viewOLRequest>/NAV_OLHeader_Item/0/PickupAddress} === ''}">
							<Text
								text="{viewOLRequest>/NAV_OLHeader_Item/0/PickupUnitNo} {viewOLRequest>/NAV_OLHeader_Item/0/PickupHouseNo} {viewOLRequest>/NAV_OLHeader_Item/0/PickupStreet} {viewOLRequest>/NAV_OLHeader_Item/0/PickupSubdivision} Brgy. {viewOLRequest>/NAV_OLHeader_Item/0/PickupBarangayDesc}, {viewOLRequest>/NAV_OLHeader_Item/0/PickupCityDesc}, {viewOLRequest>/NAV_OLHeader_Item/0/PickupProvinceDesc}, {viewOLRequest>/NAV_OLHeader_Item/0/PickupZipcode}"/>
						</f:FormElement>
						<!-- For complete pick-up address -->
						<f:FormElement label="{i18n>AdressLbl}" visible="{= ${viewOLRequest>/NAV_OLHeader_Item/0/PickupAddress} !== ''}">
							<Text text="{viewOLRequest>/NAV_OLHeader_Item/0/PickupAddress}"/>
						</f:FormElement>
						<!--Address Details if origin is from Globe-->
						<f:FormElement label="{i18n>AdressLbl}"
							visible="{= ${viewOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'G' &amp;&amp; ${viewOLRequest>/NAV_OLHeader_Item/0/PickupAddress} === ''}">
							<Text text="{viewOLRequest>/NAV_OLHeader_Item/0/PickupSpecLoc}, {viewOLRequest>/NAV_OLHeader_Item/0/PickupLocationDesc}"/>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>
				<f:FormContainer title=" ">
					<f:formElements>
						<f:FormElement>
							<f:label>
								<Label text="{i18n>PickupDateLbl}"/>
							</f:label>
							<Text text="{path: 'viewOLRequest>/NAV_OLHeader_Item/0/PickupDate', formatter: '.formatter.formatDate'}"/>
						</f:FormElement>
						<f:FormElement>
							<f:label>
								<Label text="{i18n>PickupTime}"/>
							</f:label>
							<Text
								text="{path: 'viewOLRequest>/NAV_OLHeader_Item/0/PickupTime', type: 'sap.ui.model.odata.type.Time', formatOptions: { pattern : 'HH:mm' }}"/>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>
				<!--Pick up contact-->
				<f:FormContainer title="" visible="{viewOLRequest>/NAV_OLHeader_Item/0/bShowDetails}">
					<f:formElements>
						<f:FormElement label="{i18n>ContactPersonLbl}">
							<Text text="{viewOLRequest>/NAV_OLHeader_Item/0/PickupContactPerson}"/>
						</f:FormElement>
						<f:FormElement label="{i18n>ContactNoLbl}">
							<Text text="{viewOLRequest>/NAV_OLHeader_Item/0/PickupContactNumber}"/>
						</f:FormElement>
						<f:FormElement label="{i18n>ContactEmailLbl}">
							<Text text="{viewOLRequest>/NAV_OLHeader_Item/0/PickupContactEmail}"/>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>
				<f:FormContainer title="" visible="{viewOLRequest>/NAV_OLHeader_Item/0/bShowDetails}">
					<f:formElements>
						<f:FormElement label="{i18n>AlternateContactPersonLbl}">
							<Text text="{path: 'viewOLRequest>/NAV_OLHeader_Item/0/PickupAltContactPerson' , formatter: '.formatter.formatValue'}"/>
						</f:FormElement>
						<f:FormElement label="{i18n>ContactNoLbl}">
							<Text text="{path: 'viewOLRequest>/NAV_OLHeader_Item/0/PickupAltContactNumber', formatter: '.formatter.formatValue'}"/>
						</f:FormElement>
						<f:FormElement label="{i18n>ContactEmailLbl}">
							<Text text="{path: 'viewOLRequest>/NAV_OLHeader_Item/0/PickupAltContactEmail', formatter: '.formatter.formatValue'}"/>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>
			</f:formContainers>
		</f:Form>
	</VBox>
</core:FragmentDefinition>