<core:FragmentDefinition xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified" xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
	<VBox items="{path: 'items>/', templateShareable:false}" id="editPackageVbox">
		<Panel class="dtd-customPanel sapUiMediumMarginBottom">
			<headerToolbar>
				<Toolbar height="3rem" class="dtd-customHeaderColor">
					<Text text="{items>PackageNo}" class="dtd-bold-title"/>
					<ToolbarSpacer/>
					<Button icon="sap-icon://delete" press="onDeleteItem" visible="{= ${viewModel>/PackageCount} >= 2}"/>
				</Toolbar>
			</headerToolbar>
			<content>
				<!-- Start of Form -->
				<f:Form editable="true" class="dtd-form">
					<f:layout>
						<f:ResponsiveGridLayout labelSpanXL="5" labelSpanL="5" labelSpanM="5" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"
							emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2" columnsM="2" singleContainerFullSize="false"/>
					</f:layout>
					<f:formContainers>
						<!-- Package Details -->
						<f:FormContainer title="{i18n>PackageDetailsTtl}">
							<f:formElements>
								<f:FormElement label="{i18n>ItemTypeLbl}" visible="{=${DTDRequest>/TransType} !== 'TT'}">
									<ComboBox required="true" fieldGroupIds="NT,DT" placeholder="{i18n>SelectTypePlh}" selectedKey="{items>ItemType}"
										items="{path: 'MasterData>/itemType', templateShareable: false}" change="onItemTypeChange" visible="{=${DTDRequest>/TransType} !== 'TT'}">
										<core:Item key="{MasterData>ItemType}" text="{MasterData>ItemDesc}"/>
									</ComboBox>
								</f:FormElement>
								<f:FormElement label="{i18n>itemDescriptionLbl}" visible="{=${DTDRequest>/TransType} !== 'TT'}">
									<TextArea required="true" fieldGroupIds="NT,DT"
										value="{path: 'items>ItemDescription', type: 'sap.ui.model.type.String', constraints: { minLength: 1, maxLength : 250 } }" rows="4"
										placeholder="{i18n>EnterDescriptionPlh}" change="onValueChange" visible="{=${DTDRequest>/TransType} !== 'TT'}"/>
								</f:FormElement>
								<f:FormElement label="{i18n>MaterialType}" visible="{=${DTDRequest>/TransType} === 'TT'}">
									<ComboBox required="true" fieldGroupIds="TT" placeholder="{i18n>SelectMaterialType}" selectedKey="{items>MaterialType}"
										items="{path: 'MasterData>/itemType', templateShareable: false}" change="onMaterialTypeChange"
										visible="{=${DTDRequest>/TransType} === 'TT'}">
										<core:Item key="{MasterData>ItemType}" text="{MasterData>ItemDesc}"/>
									</ComboBox>
								</f:FormElement>
								<f:FormElement label="{i18n>MaterialDescription}" visible="{=${DTDRequest>/TransType} === 'TT'}">
									<TextArea required="true" fieldGroupIds="TT"
										value="{path: 'items>MaterialDescription', type: 'sap.ui.model.type.String', constraints: { minLength: 1, maxLength : 250 } }" rows="4"
										placeholder="{i18n>EnterMaterialType}" change="onValueChange" visible="{=${DTDRequest>/TransType} === 'TT'}"/>
								</f:FormElement>
							</f:formElements>
						</f:FormContainer>
						<!-- Package attributes-->
						<f:FormContainer title=" " visible="{items>bShowDetails}">
							<f:formElements>
								<!--Start of insert MS223343 - PAL-2023-002-->
								<f:FormElement label="{i18n>manpowerServices}"
									visible="{= ${viewModel>/TransactionType} === 'NT' || ${viewModel>/TransactionType} === 'TT'}">
									<HBox>
										<Switch customTextOn=" " customTextOff=" " state="{items>ManpowerServices}" change="onManpowerChange"/>
										<ComboBox required="true" placeholder="Select" fieldGroupIds="NT,TT" selectedKey="{items>Manpower}"
											items="{path: 'ZSSD_ONELOOK_MDATA_SRV>/ZSSD_OL_MANPOWERSet', templateShareable: false}" visible="{= ${items>ManpowerServices} === true}">
											<core:Item key="{ZSSD_ONELOOK_MDATA_SRV>Manpower}" text="{parts:['ZSSD_ONELOOK_MDATA_SRV>Manpower'], formatter:'.formatter.formatManpower'}"/>
										</ComboBox>
									</HBox>
								</f:FormElement>
								<f:FormElement label="{i18n>crateServices}" visible="{= ${viewModel>/TransactionType} === 'NT' || ${viewModel>/TransactionType} === 'TT'}">
									<HBox>
										<Switch customTextOn=" " customTextOff=" " state="{items>CratingServices}" change="onCrateChange"/>
										<ComboBox required="true" placeholder="Select" fieldGroupIds="NT,TT" selectedKey="{items>Crate}"
											items="{path: 'ZSSD_ONELOOK_MDATA_SRV>/ZSSD_OL_CRATESet', templateShareable: false}" visible="{= ${items>CratingServices} === true}">
											<core:Item key="{ZSSD_ONELOOK_MDATA_SRV>Crate}" text="{ZSSD_ONELOOK_MDATA_SRV>CrateDescription}"/>
										</ComboBox>
									</HBox>
								</f:FormElement>
								<!--End of insert MS223343 - PAL-2023-002-->
								<f:FormElement label="{i18n>QuantityLbl}">
									<Input required="true" fieldGroupIds="NT,DT,TT"
										value="{path: 'items>Quantity', type: 'sap.ui.model.type.String', constraints: { minLength: 1, maxLength : 10 }}" type="Number"
										placeholder="{i18n>EnterQunatityPlh}" change="onValueChange" app:NumberType="Numeric" width="5.2rem">
										<!--<layoutData>-->
										<!--	<l:GridData span="XL2 L2 M2 S3"/>-->
										<!--</layoutData>-->
									</Input>
								</f:FormElement>
								<f:FormElement label="{i18n>WeightLbl}">
