			<!-- Shipment Details -->
			<!--Start of edit MS223343 - PAL-2023-002-->
			<!--Start of change MS223343 - PAL-2023-010-->
			<f:FormContainer title="{i18n>Shipment}" visible="{=${DTDRequest>/TransType} === 'NT' || ${DTDRequest>/TransType} === 'TT'}">
				<f:formElements>
					<f:FormElement label="{i18n>EstimatedCost}" visible="{= ${DTDRequest>/TransType} !== 'NT' }">
						<Text
							text="{path: 'items>EstimatedCost', type: 'sap.ui.model.odata.type.Decimal', constraints: { precision: 13, scale: 2, nullable: false }}"/>
					</f:FormElement>
					<f:FormElement label="{i18n>IssuingSloc}" visible="{=${DTDRequest>/TransType} === 'NT' || ${DTDRequest>/TransType} === 'TT'}">
						<Text text="{path: 'items>IssuingStorageLocation', formatter: '.formatter.formatValue'}"/>
					</f:FormElement>
					<f:FormElement label="{i18n>ReceivingSloc}" visible="{=${DTDRequest>/TransType} === 'NT' || ${DTDRequest>/TransType} === 'TT'}">
						<Text text="{path: 'items>ReceivingStorageLocation', formatter: '.formatter.formatValue'}"/>
					</f:FormElement>
				</f:formElements>
			</f:FormContainer>
			<!--End of change MS223343 - PAL-2023-010-->
			<!--End of edit MS223343 - PAL-2023-002-->
