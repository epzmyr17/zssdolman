								<f:FormElement label="{i18n>MaterialType}" visible="{=${DTDRequest>/TransType} === 'TT'}">
									<Text text="{items>MaterialTypeDesc}"/>
								</f:FormElement>
								<f:FormElement label="{i18n>MaterialDescription}" visible="{=${DTDRequest>/TransType} === 'TT'}">
									<Text text="{items>MaterialDescription}" wrapping="true"/>
								</f:FormElement>
								<f:FormElement label="{i18n>AssetNoLbl}" visible="{=${DTDRequest>/TransType} === 'NT'}">
