<core:FragmentDefinition xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified" xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
	<VBox items="{path: 'items>/', templateShareable:false}">
		<Panel class="dtd-customPanel sapUiMediumMarginBottom">
			<headerToolbar>
				<Toolbar height="4rem" class="dtd-customHeaderColor">
					<core:Icon src="{path: 'items>TransportMode', formatter: '.formatter.formatTransportModeIcon'}" tooltip="{i18n>TransportMode}"
						class="dtd-icon-size1"/>
					<VBox>
						<Text
							text="{parts: [{path: 'items>PackageNo'}, {path: 'items>ItemTypeDesc'}, {path: 'items>MaterialTypeDesc'}, {path: 'DTDRequest>/TransType'}], formatter: '.formatter.formatPackageItemDetails'}"
							class="dtd-bold-title"/>
						<Text text="{parts: [{path: 'items>DeliveryTypeDesc'}, {path: 'items>TransportMode'}], formatter: '.formatter.formatDeliveryDetails'}"/>
					</VBox>
					<ToolbarSpacer/>
					<!--Start of edit MS223343 - PAL-2023-002-->
					<VBox class="sapUiTinyMarginEnd" alignItems="End" visible="{= ${DTDRequest>/TransType} !== 'NT' }">
						<Text text="{i18n>EstimatedCost}" class="dtd-bold-title"/>
						<Text
							text="{path: 'items>EstimatedCost', type: 'sap.ui.model.odata.type.Decimal', constraints: { precision: 13, scale: 2, nullable: false }}"/>
					</VBox>
					<!--End of edit MS223343 - PAL-2023-002-->
				</Toolbar>
			</headerToolbar>
			<content>
				<Toolbar class="dtd-custom-border-bottom">
					<Button icon="sap-icon://edit" text="{i18n>EditDetails}" press="onPrevious" class="dtd-custom-no-border-button"/>
