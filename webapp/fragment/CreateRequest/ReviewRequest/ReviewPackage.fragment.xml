								<f:FormElement label="{i18n>manpowerServices}" visible="{= ${DTDRequest>/TransType} === 'NT' || ${DTDRequest>/TransType} === 'TT'}">
									<HBox>
										<Switch enabled="false" customTextOn=" " customTextOff=" " state="{items>ManpowerServices}"/>
										<ComboBox enabled="false" selectedKey="{items>Manpower}"
											items="{path: 'ZSSD_ONELOOK_MDATA_SRV>/ZSSD_OL_MANPOWERSet', templateShareable: false}" visible="{= ${items>ManpowerServices} === true}">
