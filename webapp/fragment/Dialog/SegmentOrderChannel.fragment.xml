<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
	<TableSelectDialog 
		title="{i18n>SelectSegmentOrder}"
		search="onSearchSegmentOrder"
		confirm="onSelectSegmentOrder"
		cancel="onCancelValueHelp"
		items="{path: 'ZSSD_ONELOOK_MDATA_SRV>/ZSSD_CHANNELSet'}"
		growingThreshold="100">
		<ColumnListItem>
			<cells>
				<ObjectIdentifier title="{ZSSD_ONELOOK_MDATA_SRV>SegmentOrder}"/>
				<Text text="{ZSSD_ONELOOK_MDATA_SRV>SegmentType}"/>
				<Text text="{ZSSD_ONELOOK_MDATA_SRV>ActivityDesc}"/>
			</cells>
		</ColumnListItem>
		<columns>
			<Column>
				<header>
					<Text text="{i18n>SegmentOrder}"/>
				</header>
			</Column>
			<Column>
				<header>
					<Text text="{i18n>SegmentOrderType}"/>
				</header>
			</Column>
			<Column>
				<header>
					<Text text="{i18n>Activity}"/>
				</header>
			</Column>
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>