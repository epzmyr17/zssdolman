<core:FragmentDefinition xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified" xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
	<VBox id="idVBoxContainer" items="{path: 'editOLRequest>/NAV_OLHeader_Item', templateShareable:false}">
		<Panel class="dtd-customPanel sapUiMediumMarginBottom">
			<headerToolbar>
				<Toolbar height="3rem" class="dtd-customHeaderColor">
					<Text text="{editOLRequest>PackageNo}" class="dtd-bold-title"/>
					<ToolbarSpacer/>
					<Button icon="sap-icon://delete" press="onDeleteItem" visible="{= ${editOLRequest>/NAV_OLHeader_Item}.length >= 2}"/>
				</Toolbar>
			</headerToolbar>
			<content>
				<!-- Start of Form -->
				<f:Form editable="true" class="dtd-form">
					<f:layout>
						<f:ResponsiveGridLayout labelSpanXL="5" labelSpanL="5" labelSpanM="5" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"
							emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2" columnsM="2" singleContainerFullSize="false"/>
					</f:layout>
					<f:formContainers>
						<!-- Package Details -->
						<f:FormContainer title="{i18n>PackageDetailsTtl}">
							<f:formElements>
								<f:FormElement label="{i18n>ItemTypeLbl}" visible="{=${editOLRequest>/TransType} !== 'TT'}">
									<ComboBox required="true" fieldGroupIds="NT,DT" placeholder="{i18n>SelectTypePlh}" selectedKey="{editOLRequest>ItemType}"
										items="{path: 'MasterData>/itemType', templateShareable: false}" change="onItemTypeChange" visible="{=${editOLRequest>/TransType} !== 'TT'}">
										<core:Item key="{MasterData>ItemType}" text="{MasterData>ItemDesc}"/>
									</ComboBox>
								</f:FormElement>
								<f:FormElement label="{i18n>itemDescriptionLbl}" visible="{=${editOLRequest>/TransType} !== 'TT'}">
									<TextArea required="true" fieldGroupIds="NT,DT"
										value="{path: 'editOLRequest>ItemDescription', type: 'sap.ui.model.type.String', constraints: { minLength: 1, maxLength : 250} }" rows="4"
										placeholder="{i18n>EnterDescriptionPlh}" change="onValueChange" visible="{=${editOLRequest>/TransType} !== 'TT'}"/>
								</f:FormElement>
								<f:FormElement label="{i18n>MaterialType}" visible="{=${editOLRequest>/TransType} === 'TT'}">
									<ComboBox required="true" fieldGroupIds="TT" placeholder="{i18n>SelectMaterialType}" selectedKey="{editOLRequest>MaterialType}"
										items="{path: 'MasterData>/itemType', templateShareable: false}" change="onMaterialTypeChange"
										visible="{=${editOLRequest>/TransType} === 'TT'}">
										<core:Item key="{MasterData>ItemType}" text="{MasterData>ItemDesc}"/>
									</ComboBox>
								</f:FormElement>
								<f:FormElement label="{i18n>MaterialDescription}" visible="{=${editOLRequest>/TransType} === 'TT'}">
									<TextArea required="true" fieldGroupIds="TT"
										value="{path: 'editOLRequest>MaterialDescription', type: 'sap.ui.model.type.String', constraints: { minLength: 1, maxLength : 250 } }"
										rows="4" placeholder="{i18n>EnterMaterialType}" change="onValueChange" visible="{=${editOLRequest>/TransType} === 'TT'}"/>
								</f:FormElement>
							</f:formElements>
						</f:FormContainer>
						<!-- Package attributes-->
						<f:FormContainer title=" " visible="{editOLRequest>bShowDetails}">
