									<HBox>
										<Switch customTextOn=" " customTextOff=" " state="{editOLRequest>ManpowerServices}" change="onManpowerChange"/>
										<ComboBox required="true" placeholder="Select" fieldGroupIds="NT,TT" selectedKey="{editOLRequest>Manpower}"
											items="{path: 'ZSSD_ONELOOK_MDATA_SRV>/ZSSD_OL_MANPOWERSet', templateShareable: false}"
											visible="{= ${editOLRequest>ManpowerServices} === true}">
											<core:Item key="{ZSSD_ONELOOK_MDATA_SRV>Manpower}" text="{parts:['ZSSD_ONELOOK_MDATA_SRV>Manpower'], formatter:'.formatter.formatManpower'}"/>
										</ComboBox>
									</HBox>
								</f:FormElement>
								<f:FormElement label="{i18n>crateServices}" visible="{= ${editOLRequest>/TransType} === 'NT' || ${editOLRequest>/TransType} === 'TT'}">
									<HBox>
										<Switch customTextOn=" " customTextOff=" " state="{editOLRequest>CratingServices}" change="onCrateChange"/>
										<ComboBox required="true" placeholder="Select" fieldGroupIds="NT,TT" selectedKey="{editOLRequest>Crate}"
											items="{path: 'ZSSD_ONELOOK_MDATA_SRV>/ZSSD_OL_CRATESet', templateShareable: false}" visible="{= ${editOLRequest>CratingServices} === true}">
											<core:Item key="{ZSSD_ONELOOK_MDATA_SRV>Crate}" text="{ZSSD_ONELOOK_MDATA_SRV>CrateDescription}"/>
										</ComboBox>
									</HBox>
								</f:FormElement>
								<!--End of insert MS223343 - PAL-2023-002-->
								<f:FormElement label="{i18n>QuantityLbl}">
									<Input required="true" fieldGroupIds="NT,DT,TT"
										value="{path: 'editOLRequest>Quantity', type: 'sap.ui.model.type.Integer', constraints: { minLength: 1, maxLength: 10 }}" type="Number"
										placeholder="{i18n>EnterQunatityPlh}" change="onValueChange" app:NumberType="Numeric" width="5.2rem">
										<!--<layoutData>-->
										<!--	<l:GridData span="XL2 L2 M2 S3"/>-->
										<!--</layoutData>-->
									</Input>
								</f:FormElement>
								<f:FormElement label="{i18n>WeightLbl}">
