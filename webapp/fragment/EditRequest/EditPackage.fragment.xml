											placeholder="{i18n>LengthPlh}" change="onValueChange" app:NumberType="Decimal" width="5.2rem">
											<!--<layoutData>-->
											<!--	<l:GridData span="XL3 L2 M2 S2"/>-->
											<!--</layoutData>-->
										</Input>
										<Text text="x" textAlign="Center" class="sapUiTinyMarginBeginEnd">
											<!--<layoutData>-->
											<!--	<l:GridData span="XL1 L1 M1 S1" indent="XL0 L0 M0 S0"/>-->
											<!--</layoutData>-->
										</Text>
										<Input required="true" fieldGroupIds="NT"
											value="{path: 'editOLRequest>Width', type: 'sap.ui.model.type.String', constraints: { minLength: 1, maxLength : 10 }}" type="Number"
											placeholder="{i18n>WidthPlh}" change="onValueChange" app:NumberType="Decimal">
											<!--<layoutData>-->
											<!--	<l:GridData span="XL3 L2 M2 S3"/>-->
											<!--</layoutData>-->
										</Input>
										<Text text="x" textAlign="Center" class="sapUiTinyMarginBeginEnd">
											<!--<layoutData>-->
											<!--	<l:GridData span="XL1 L1 M1 S1"/>-->
											<!--</layoutData>-->
										</Text>
										<Input required="true" fieldGroupIds="NT"
