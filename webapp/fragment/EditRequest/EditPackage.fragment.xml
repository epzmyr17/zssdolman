										value="{path: 'editOLRequest>Weight', type: 'sap.ui.model.type.String', constraints: { minLength: 1, maxLength : 10 }}" type="Number"
										placeholder="{i18n>EnterWeightPlh}" change="onValueChange" app:NumberType="Decimal" width="5.2rem">
										<!--<layoutData>-->
										<!--	<l:GridData span="XL2 L2 M2 S3"/>-->
										<!--</layoutData>-->
									</Input>
								</f:FormElement>
								<f:FormElement label="{i18n>VolumeLbl}" visible="{= ${editOLRequest>/TransType} === 'NT'}">
