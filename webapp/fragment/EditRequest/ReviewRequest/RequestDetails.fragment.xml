<core:FragmentDefinition xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core"
	xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
	<Panel class="dtd-customPanel sapUiMediumMarginBottom">
		<headerToolbar>
			<Toolbar height="4rem" class="dtd-customHeaderColor">
				<!--Start of change MS223343 - PAL-2023-004 / 007-->
				<VBox>
					<HBox>
						<Text text="{i18n>TotalRequest}" class="sapUiTinyMarginBottom"/>
						<Text text="{path: 'viewModel>/PackageCount', formatter: '.formatter.formatPackageCount'}" class="dtd-bold-title sapUiTinyMarginBottom"/>
					</HBox>
					<HBox visible="{= ${viewModel>/TransactionType} === 'NT'}">
						<Text text="{i18n>chargeableWeight}" class="sapUiTinyMarginBottom"/>
						<Text text="{MasterData>/ChargeableWeight}" class="dtd-bold-title sapUiTinyMarginBottom"/>
					</HBox>
				</VBox>
				<!--End of change MS223343 - PAL-2023-004 / 007-->
				<ToolbarSpacer/>
				<VBox class="sapUiTinyMarginEnd" alignItems="End">
					<Text text="{i18n>TotalCost}" class="sapUiTinyMarginBottom" textAlign="End"/>
					<Text
						text="{parts:[{path: 'editOLRequest>TotalEstimatedCost'},{path: 'editOLRequest>Currency'}], type: 'sap.ui.model.type.Currency', formatOptions:{showMeasure: false}}"
						class="dtd-bold-title dtd-custom-title-size" textAlign="End"/>
				</VBox>
			</Toolbar>
		</headerToolbar>
		<content>
			<f:Form editable="true" class="dtd-form">
				<f:layout>
					<f:ResponsiveGridLayout labelSpanXL="5" labelSpanL="5" labelSpanM="4" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"
						emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2" columnsM="2" singleContainerFullSize="false"/>
				</f:layout>
				<f:formContainers>
					<f:FormContainer title="{i18n>RequestApprover}"
						visible="{= ${viewModel>/TransactionType} !== 'DT' &amp;&amp; ${UserType>/UserType} === 'R'}">
						<f:formElements>
							<f:FormElement label="{i18n>ApproveBy}">
								<Input placeholder="{i18n>EnterSupervisor}" value="{editOLRequest>Approver}" required="true" fieldGroupIds="NT,TT" showValueHelp="true"
									valueHelpOnly="true" valueHelpRequest="onValueHelpApprover" app:ModelAlias="editOLRequest"
									visible="{= ${viewModel>/TransactionType} !== 'DT' &amp;&amp; ${UserType>/UserType} === 'R'}"/>
							</f:FormElement>
						</f:formElements>
					</f:FormContainer>
					<f:FormContainer visible="{= ${viewModel>/TransactionType} !== 'DT' &amp;&amp; ${UserType>/UserType} === 'R'}"/>
					<f:FormContainer title="{i18n>RequestDetails}">
						<f:formElements>
							<!--Start of insert - MS223343 - PAL-2023-003-->
							<f:FormElement label="{i18n>IOChargingAccount}">
								<Input id="IOChargingAccountInput" placeholder="{i18n>EnterIOChargingAccount}"
									value="{path: 'editOLRequest>/IOChargingAccount', type: 'sap.ui.model.type.String', constraints: {maxLength: 12}}" change="onCodeChange"
									app:NumberType="Numeric"/>
							</f:FormElement>
							<!--End of insert - MS223343 - PAL-2023-003-->
							<f:FormElement label="{i18n>WbsCode}">
								<Input id="WbsCodeInput" placeholder="{i18n>EnterWbs}"
									value="{path: 'editOLRequest>WbsCode', type: 'sap.ui.model.type.String', constraints: {maxLength : 24}}" change="onCodeChange"/>
							</f:FormElement>
							<!--Start of edit - MS223343 - PAL-2023-003-->
							<f:FormElement label="{i18n>CompanyCode}">
								<ComboBox required="true" fieldGroupIds="NT,DT,TT" placeholder="{i18n>SelectCompanyCode}"
									items="{path: 'LocalMasterData>/CompanyCode', templateShareable: false}" selectedKey="{editOLRequest>CompanyCode}" change="onCompanyChange">
									<core:Item key="{LocalMasterData>id}" text="{LocalMasterData>Description}"/>
								</ComboBox>
							</f:FormElement>
							<f:FormElement label="{i18n>CCCode}">
								<Input id="CCCodeInput" placeholder="{i18n>EnterCCCode}" enabled="{= ${editOLRequest>/CompanyCode} !== '' }"
									value="{path: 'editOLRequest>CostCenter', type: 'sap.ui.model.type.String', constraints: {maxLength: 10}}" showValueHelp="true"
									valueHelpOnly="true" valueHelpRequest="onValueHelpCCcode" change="onCodeChange" app:ModelAlias="editOLRequest"/>
							</f:FormElement>
							<f:FormElement label="">
								<Text text="{MasterData>/costCenterNode/CostCenter}"/>
							</f:FormElement>
							<!--End of edit - MS223343 - PAL-2023-003-->
						</f:formElements>
					</f:FormContainer>
				</f:formContainers>
			</f:Form>
		</content>
	</Panel>
</core:FragmentDefinition>