<core:FragmentDefinition xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified" xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
	<VBox class="sapUiContentPadding dtd-customPanel sapUiMediumMarginBottom">
		<f:Form editable="false" class="dtd-form">
			<f:layout>
				<f:ResponsiveGridLayout labelSpanXL="5" labelSpanL="5" labelSpanM="5" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"
					emptySpanM="0" emptySpanS="0" columnsXL="3" columnsL="2" columnsM="2" singleContainerFullSize="false"/>
			</f:layout>
			<f:formContainers>
				<f:FormContainer title="{i18n>DeliveryTtl}">
					<f:formElements>
						<f:FormElement label="{i18n>DeliveryLocationLbl}">
							<Text text="{editOLRequest>/NAV_OLHeader_Item/0/DeliveryOriginDesc}"/>
						</f:FormElement>
						<!--Address Details if origin is from O, warehouse, supplier and e-waste-->
						<f:FormElement label="{i18n>AdressLbl}"
							visible="{=${editOLRequest>/NAV_OLHeader_Item/0/DeliveryOrigin} === 'O' || (${editOLRequest>/NAV_OLHeader_Item/0/DeliveryOrigin} !== 'G' &amp;&amp; ${editOLRequest>/NAV_OLHeader_Item/0/DeliveryOrigin} !== '')}">
							<Text
								text="{editOLRequest>/NAV_OLHeader_Item/0/DeliveryUnitNo} {editOLRequest>/NAV_OLHeader_Item/0/DeliveryHouseNo} {editOLRequest>/NAV_OLHeader_Item/0/DeliveryStreet} {editOLRequest>/NAV_OLHeader_Item/0/DeliverySubdivision} Brgy. {editOLRequest>/NAV_OLHeader_Item/0/DeliveryBarangayDesc}, {editOLRequest>/NAV_OLHeader_Item/0/DeliveryCityDesc}, {editOLRequest>/NAV_OLHeader_Item/0/DeliveryProvinceDesc}, {editOLRequest>/NAV_OLHeader_Item/0/DeliveryZipcode}"/>
						</f:FormElement>
						<!--Address Details if origin is from Globe-->
						<f:FormElement label="{i18n>AdressLbl}" visible="{= ${editOLRequest>/NAV_OLHeader_Item/0/DeliveryOrigin} === 'G'}">
							<Text text="{editOLRequest>/NAV_OLHeader_Item/0/DeliverySpecLoc}, {editOLRequest>/NAV_OLHeader_Item/0/DeliveryLocationDesc}"/>
						</f:FormElement>
						<f:FormElement label="{i18n>ModeOfTransportLbl}" visible="{editOLRequest>/NAV_OLHeader_Item/0/bShowDetails}">
							<Text text="{editOLRequest>/NAV_OLHeader_Item/0/TransportModeDesc}"/>
						</f:FormElement>
						<!--if Sea-->
						<f:FormElement label="{i18n>ContainerType}"
							visible="{= ${editOLRequest>/NAV_OLHeader_Item/0/TransportMode} !== '' &amp;&amp; ${editOLRequest>/NAV_OLHeader_Item/0/TransportMode} === 'SEA' &amp;&amp; ${editOLRequest>/TransType} !== 'DT'}">
							<Text text="{editOLRequest>/NAV_OLHeader_Item/0/ContainerTypeDesc}"/>
						</f:FormElement>
						<f:FormElement label="{i18n>DeliveryTypeLbl}" visible="{editOLRequest>/NAV_OLHeader_Item/0/bShowDetails}">
							<Text text="{editOLRequest>/NAV_OLHeader_Item/0/DeliveryTypeDesc}"/>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>
				<!--Delivery Date-->
				<f:FormContainer title=" ">
					<f:formElements>
						<f:FormElement label="{i18n>DeliveryDate}">
							<Text text="{path: 'editOLRequest>/NAV_OLHeader_Item/0/DeliveryDate', formatter: '.formatter.formatDate'}"/>
						</f:FormElement>
						<f:FormElement label="{i18n>DeliveryTime}">
							<Text text="{path: 'editOLRequest>/NAV_OLHeader_Item/0/DeliveryTime', formatter: '.formatter.formatTime'}"/>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>
				<!--Delivery contact person-->
				<f:FormContainer title="" visible="{editOLRequest>/NAV_OLHeader_Item/0/bShowDetails}">
					<f:formElements>
						<f:FormElement label="{i18n>AuthRecipient}">
							<Text text="{editOLRequest>/NAV_OLHeader_Item/0/DeliveryContactPerson}"/>
						</f:FormElement>
						<f:FormElement label="{i18n>ContactNoLbl}">
							<Text text="{editOLRequest>/NAV_OLHeader_Item/0/DeliveryContactNumber}"/>
						</f:FormElement>
						<f:FormElement label="{i18n>ContactEmailLbl}">
							<Text text="{editOLRequest>/NAV_OLHeader_Item/0/DeliveryContactEmail}"/>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>
				<f:FormContainer title="" visible="{editOLRequest>/NAV_OLHeader_Item/0/bShowDetails}">
					<f:formElements>
						<f:FormElement label="{i18n>AltAutRecipient}">
							<Text text="{path: 'editOLRequest>/NAV_OLHeader_Item/0/DeliveryAltContactPerson', formatter: '.formatter.formatValue'}"/>
						</f:FormElement>
						<f:FormElement label="{i18n>ContactNoLbl}">
							<Text text="{path: 'editOLRequest>/NAV_OLHeader_Item/0/DeliveryAltContactNumber', formatter: '.formatter.formatValue'}"/>
						</f:FormElement>
						<f:FormElement label="{i18n>ContactEmailLbl}">
							<Text text="{path: 'editOLRequest>/NAV_OLHeader_Item/0/DeliveryAltContactEmail', formatter: '.formatter.formatValue'}"/>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>
			</f:formContainers>
		</f:Form>
	</VBox>
</core:FragmentDefinition>