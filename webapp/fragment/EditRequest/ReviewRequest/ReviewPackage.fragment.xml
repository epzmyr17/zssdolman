					</VBox>
					<ToolbarSpacer/>
					<!--Start of edit MS223343 - PAL-2023-002-->
					<VBox class="sapUiTinyMarginEnd" alignItems="End" visible="{= ${editOLRequest>/TransType} !== 'NT' }">
