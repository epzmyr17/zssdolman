<core:FragmentDefinition xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core"
	xmlns:u="sap.ui.unified" xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
	<VBox class="sapUiContentPadding dtd-customPanel sapUiMediumMarginBottom">
		<f:Form editable="true" class="dtd-form">
			<f:layout>
				<f:ResponsiveGridLayout labelSpanXL="5" labelSpanL="5" labelSpanM="5" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="0" emptySpanL="0"
					emptySpanM="0" emptySpanS="0" columnsXL="2" columnsL="2" columnsM="2" singleContainerFullSize="false"/>
			</f:layout>
			<f:formContainers>
				<!--Pickup Details-->
				<f:FormContainer title="{i18n>PickUpTtl}" visible="{editOLRequest>/NAV_OLHeader_Item/0/bShowDetails}">
					<f:formElements>
						<f:FormElement label="{i18n>PickUpLocationLbl}">
							<ComboBox required="true" fieldGroupIds="NT,DT,TT" app:DetailInfo="Pickup" placeholder="{i18n>LocPhl}"
								items="{path: 'ZSSD_ONELOOK_MDATA_SRV>/ZSSD_PICKUP_LOCSet', templateShareable: false}"
								selectedKey="{editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin}" change="onLocationChange">
								<core:Item key="{ZSSD_ONELOOK_MDATA_SRV>PICKUP_LOC}" text="{ZSSD_ONELOOK_MDATA_SRV>PICKUP_DESC}"/>
							</ComboBox>
						</f:FormElement>
						<!--Address Details if origin is from Others-->
						<!-- Start of Adress breakdown -->
						<f:FormElement visible="{=${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'O'}" label="{i18n>AdressLbl}">
							<!-- start - display only when others is selected as location-->
							<Input value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupUnitNo', type: 'sap.ui.model.type.String', constraints: {maxLength : 30 }}"
								placeholder="{i18n>UnitNo}">
								<layoutData>
									<l:GridData span="XL2 L2 M2 S3"/>
								</layoutData>
							</Input>
							<Input value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupHouseNo', type: 'sap.ui.model.type.String', constraints: {maxLength : 30 }}"
								placeholder="{i18n>HouseNo}">
								<layoutData>
									<l:GridData span="XL2 L2 M2 S3"/>
								</layoutData>
							</Input>
							<Input value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupStreet', type: 'sap.ui.model.type.String', constraints: {maxLength : 60 }}"
								placeholder="{i18n>EnterStreet}"/>
							<!--end - display only when others is selected as location-->
						</f:FormElement>
						<f:FormElement label="{i18n>SubdivisionArea}" visible="{= ${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'O'}">
							<!--subdivision-->
							<Input
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupSubdivision', type: 'sap.ui.model.type.String', constraints: {maxLength : 60 }}"
								placeholder="{i18n>EnterSubdivision}"/>
							<!--region-->
							<ComboBox fieldGroupIds="NT,DT,TT" app:DetailInfo="Pickup" selectedKey="{editOLRequest>/NAV_OLHeader_Item/0/PickupArea}"
								items="{path: 'ZSSD_ONELOOK_MDATA_SRV>/ZSSD_AREASet', templateShareable: false}" change="onAreaChange" placeholder="{i18n>SelRegionPhl}"
								visible="{= ${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'O'}" required="true">
								<core:Item key="{ZSSD_ONELOOK_MDATA_SRV>AreaCode}" text="{ZSSD_ONELOOK_MDATA_SRV>AreaDesc}"/>
							</ComboBox>
						</f:FormElement>
						<f:FormElement label="{i18n>ProvinceCity}" visible="{=${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'O'}">
							<!-- Province -->
							<Input fieldGroupIds="NT,DT,TT" app:DetailInfo="Pickup" app:ModelAlias="editOLRequest"
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupProvinceDesc', type: 'sap.ui.model.type.String', constraints: {minLength: 1}}"
								required="true" placeholder="{i18n>SelProvincePhl}" enabled="{= (${editOLRequest>/NAV_OLHeader_Item/0/PickupArea} ? true : false) }"
								visible="{= ${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'O'}" valueHelpOnly="true" showValueHelp="true"
								valueHelpRequest="onValueHelpProvince"/>
							<!-- City -->
							<Input fieldGroupIds="NT,DT,TT" app:DetailInfo="Pickup" app:ModelAlias="editOLRequest"
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupCityDesc', type: 'sap.ui.model.type.String', constraints: {minLength: 1}}"
								required="true" placeholder="{i18n>SelCityPhl}" enabled="{= (${editOLRequest>/NAV_OLHeader_Item/0/PickupProvince} ? true : false) }"
								visible="{= ${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'O'}" valueHelpOnly="true" showValueHelp="true"
								valueHelpRequest="onValueHelpCity"/>
						</f:FormElement>
						<f:FormElement label="{i18n>BrgyZipcode}" visible="{= ${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'O'}">
							<!-- Barangay -->
							<Input fieldGroupIds="NT,DT,TT" app:DetailInfo="Pickup" app:ModelAlias="editOLRequest" required="true"
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupBarangayDesc', type: 'sap.ui.model.type.String', constraints: {minLength: 1}}"
								placeholder="{i18n>SelBrgy}" enabled="{= (${editOLRequest>/NAV_OLHeader_Item/0/PickupCity} ? true : false) }"
								visible="{= ${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'O'}" valueHelpOnly="true" showValueHelp="true"
								valueHelpRequest="onValueHelpBrgy"/>
							<!-- Zipcode -->
							<Input fieldGroupIds="NT,DT,TT"
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupZipcode', type: 'sap.ui.model.type.String', constraints: {minLength: 1, maxLength : 4 }}"
								placeholder="{i18n>EnterZipcode}" type="Number" visible="{= ${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'O'}"
								change="onValueChange" app:NumberType="Numeric" required="true"/>
						</f:FormElement>
						<!-- End of Adress breakdown -->
						<!--Address Details if origin is from Globe-->
						<f:FormElement label="{i18n>AdressLbl}"
							visible="{= ${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} !== '' &amp;&amp; typeof(${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin}) !== 'undefined' &amp;&amp; ${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} !== 'O'}">
							<!-- hide if Other were selected as location -->
							<Input required="true" fieldGroupIds="NT,DT,TT" app:DetailInfo="Pickup" app:ModelAlias="editOLRequest" placeholder="{i18n>SelAddressPhl}"
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupLocationDesc', type: 'sap.ui.model.type.String', constraints: {minLength: 1}}"
								visible="{= ${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} !== '' &amp;&amp; typeof(${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin}) !== 'undefined' &amp;&amp; ${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} !== 'O'}"
								valueHelpOnly="true" showValueHelp="true" valueHelpRequest="onValueHelpAddress"/>
						</f:FormElement>
						<!--Display only when G were selected as location -->
						<f:FormElement label="{i18n>SpecificLocation}" visible="{=${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'G'}">
							<Input fieldGroupIds="NT,DT,TT"
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupSpecLoc', type: 'sap.ui.model.type.String', constraints: {maxLength : 25 }}"
								placeholder="{i18n>DetailedLocation}" visible="{=${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} === 'G'}" change="onValueChange"
								required="true"/>
						</f:FormElement>
						<!-- Start of Adress breakdown -->
						<!-- unit no, house no , street -->
						<f:FormElement label="{i18n>PickupAddress}"
							visible="{= (${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} !== 'O' &amp;&amp; ${editOLRequest>/NAV_OLHeader_Item/0/PickupOrigin} !== 'G') &amp;&amp; ${editOLRequest>/NAV_OLHeader_Item/0/PickupLocation} !== ''}">
							<TextArea
								value="{editOLRequest>/NAV_OLHeader_Item/0/PickupUnitNo} {editOLRequest>/NAV_OLHeader_Item/0/PickupHouseNo} {editOLRequest>/NAV_OLHeader_Item/0/PickupStreet} {editOLRequest>/NAV_OLHeader_Item/0/PickupSubdivision} Brgy. {editOLRequest>/NAV_OLHeader_Item/0/PickupBarangayDesc}, {editOLRequest>/NAV_OLHeader_Item/0/PickupCityDesc}, {editOLRequest>/NAV_OLHeader_Item/0/PickupProvinceDesc}, {editOLRequest>/NAV_OLHeader_Item/0/PickupZipcode}"
								growing="true" growingMaxLines="4" enabled="false"/>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>
				<f:FormContainer title=" " visible="{editOLRequest>/NAV_OLHeader_Item/0/bShowDetails}">
					<f:formElements>
						<f:FormElement label="{i18n>PickupDateLbl}">
							<DatePicker required="true" fieldGroupIds="NT,DT,TT"
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupDate', type : 'sap.ui.model.type.DateTime', formatOptions:{ pattern : 'MM/dd/yyyy'}}"
								valueFormat="yyyy-MM-dd" minDate="{viewModel>/MinDate}" change="onValueChange"/>
						</f:FormElement>
						<f:FormElement label="{i18n>PickupTime}">
							<TimePicker required="true" fieldGroupIds="NT,DT,TT"
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupTime', type : 'sap.ui.model.type.Time', formatOptions:{ pattern : 'HH:mm'}}"
								valueFormat="HH:mm" change="onValueChange"/>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>
				<!--Pickup contact-->
				<f:FormContainer title="" visible="{editOLRequest>/NAV_OLHeader_Item/0/bShowDetails}">
					<f:formElements>
						<f:FormElement label="{i18n>ContactPersonLbl}">
							<Input required="true" fieldGroupIds="NT,DT,TT"
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupContactPerson', type: 'sap.ui.model.type.String', constraints: {minLength: 1, maxLength: 30}}"
								placeholder="{i18n>EnterFullName}" change="onValueChange"/>
						</f:FormElement>
						<f:FormElement label="{i18n>ContactNoLbl}">
							<Input required="true" fieldGroupIds="NT,DT,TT"
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupContactNumber', type: 'sap.ui.model.type.String', constraints:{minLength: 7, maxLength: 11}}"
								placeholder="{i18n>EnterContactNo}" type="Number" change="onValueChange" app:NumberType="Numeric"/>
							<!-- for mobile number -->
						</f:FormElement>
						<f:FormElement label="{i18n>ContactEmailLbl}">
							<Input required="{=${viewModel>/TransactionType} !== 'TT'}" fieldGroupIds="NT,DT,TT"
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupContactEmail',type: 'sap.ui.model.type.String', constraints:{maxLength: 60}}"
								placeholder="{i18n>EnterEmail}" type="Email" change="onValueChange"/>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>
				<!-- Pickup Alternate contact-->
				<f:FormContainer title="" visible="{editOLRequest>/NAV_OLHeader_Item/0/bShowDetails}">
					<f:formElements>
						<f:FormElement label="{i18n>AlternateContactPersonLbl}">
							<Input
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupAltContactPerson', type: 'sap.ui.model.type.String', constraints: {maxLength: 30}}"
								placeholder="{i18n>EnterFullName}" fieldGroupIds="NT,DT,TT"/>
						</f:FormElement>
						<f:FormElement label="{i18n>ContactNoLbl}">
							<Input
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupAltContactNumber', type: 'sap.ui.model.type.String', constraints:{maxLength: 11}}"
								placeholder="{i18n>EnterContactNo}" fieldGroupIds="NT,DT,TT" type="Number" app:NumberType="Numeric"/>
						</f:FormElement>
						<f:FormElement label="{i18n>ContactEmailLbl}">
							<Input
								value="{path: 'editOLRequest>/NAV_OLHeader_Item/0/PickupAltContactEmail', type: 'sap.ui.model.type.String', constraints: {maxLength: 60}}"
								placeholder="{i18n>EnterEmail}" type="Email" fieldGroupIds="NT,DT,TT" change="onValueChange"/>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>
			</f:formContainers>
		</f:Form>
	</VBox>
</core:FragmentDefinition>