<mvc:View controllerName="com.globe.OneLook_CreateDTDRequest.controller.Report" xmlns:mvc="sap.ui.core.mvc" xmlns:fb="sap.ui.comp.filterbar"
	xmlns:f="sap.f" displayBlock="true" xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:smartTable="sap.ui.comp.smarttable"
	xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
	<f:DynamicPage id="dynamicPageId" class="sapUiNoContentPadding">
		<f:title>
			<f:DynamicPageTitle>
				<f:heading>
					<Title text="{i18n>MySubmitReq}"/>
				</f:heading>
				<f:breadcrumbs>
					<Breadcrumbs currentLocationText="{i18n>MySubmitReq}">
						<Link text="{i18n>Home}" press="onPressBreadCrumbs">
							<customData>
								<core:CustomData key="route" value="#"/>
							</customData>
						</Link>
					</Breadcrumbs>
				</f:breadcrumbs>
				<f:actions></f:actions>
				<f:navigationActions>
					<Button type="Transparent" text="{i18n>ClearFilter}" press="onClearFilter"/>
					<Button type="Emphasized" text="{i18n>NewRequest}" press="onPressNewRequest" class="sapUiSmallMarginEnd"/>
				</f:navigationActions>
			</f:DynamicPageTitle>
		</f:title>
		<f:header>
			<f:DynamicPageHeader pinnable="true" class="dtd-dynamic-page-header">
				<f:content>
					<fb:FilterBar reset="onReset" search="onChangeFilterBar" showFilterConfiguration="true" useToolbar="false" showRestoreButton="false"
						showClearButton="false" showGoOnFB="true">
						<fb:filterItems>
							<fb:FilterItem name="RefNo" label="{i18n>ReferenceNo}">
								<fb:control>
									<Input id="idRefNoFilter" value="{ReportFilter>Recnum}" liveChange="onChangeFieldValue">
										<customData>
											<core:CustomData value="{/#OLHeaderSet/StatusId/@name}"/>
										</customData>
									</Input>
								</fb:control>
							</fb:FilterItem>
							<fb:FilterItem name="DateSubmitted" label="{i18n>DateSubmitted}">
								<fb:control>
									<DateRangeSelection id="idDateSubmittedFilter" change="onChangeFieldValue" class="dtd-daterange-input-disable" dateValue="{ReportFilter>FromDate}"
										secondDateValue="{ReportFilter>ToDate}"/>
								</fb:control>
							</fb:FilterItem>
							<fb:FilterItem name="TransType" label="{i18n>TransType}">
								<fb:control>
									<Select forceSelection="false" items="{ path: 'ZSSD_ONELOOK_MDATA_SRV>/ZSSD_TRANS_TYPESet' }" selectedKey="{ReportFilter>TransType}">
										<core:Item text="{ZSSD_ONELOOK_MDATA_SRV>TRANS_DESC}" key="{ZSSD_ONELOOK_MDATA_SRV>TRANS_TYPE}"/>
									</Select>
								</fb:control>
							</fb:FilterItem>
							<fb:FilterItem name="Status" label="{i18n>Status}">
								<fb:control>
									<Select id="idSelectStatus" forceSelection="false" items="{ path: 'ZSSD_ONELOOK_MDATA_SRV>/ZSSD_OL_STATUS_IDSet',
										filters: [{path: 'ApplicationId', operator: 'EQ', value1: 'R'}]}" selectedKey="{ReportFilter>Status}">
										<core:Item text="{ZSSD_ONELOOK_MDATA_SRV>StatusIdDesc}" key="{ZSSD_ONELOOK_MDATA_SRV>StatusId}"/>
									</Select>
								</fb:control>
							</fb:FilterItem>
							<fb:FilterItem name="BssCase" label="{i18n>BssCase}" visibleInFilterBar="false">
								<fb:control>
									<Input value="{ReportFilter>BssCase}"/>
								</fb:control>
							</fb:FilterItem>
							<fb:FilterItem name="Sto" label="{i18n>Sto}" visibleInFilterBar="false">
								<fb:control>
									<Input value="{ReportFilter>Sto}"/>
								</fb:control>
							</fb:FilterItem>
							<fb:FilterItem name="DelOrder" label="{i18n>DelOrder}" visibleInFilterBar="false">
								<fb:control>
									<Input value="{ReportFilter>DeliveryOrder}"/>
								</fb:control>
							</fb:FilterItem>
						</fb:filterItems>
					</fb:FilterBar>
					<!--<IconTabBar id="idIconTabFilter" select="onSelectTabStatus" showOverflowSelectList="true" headerMode="Inline" upperCase="false"-->
					<!--	expanded="true" expandable="false" applyContentPadding="false" class="dtd-icon-tab-no-margin dtd-icon-tab-no-border-bottom"-->
					<!--	items="{ path: '/ReportTabSet', filters: [{path: 'Application', operator: 'EQ', value1: 'R'}], parameters: { expand: 'NavTo_ReportTab_Status'},-->
