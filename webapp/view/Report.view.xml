					<!--	<items>-->
					<!--		<IconTabFilter text="{TabDesc}" key="{TabId}"/>-->
					<!--	</items>-->
					<!--</IconTabBar>-->
					<IconTabBar id="idIconTabFilter" select="onSelectTabStatus" showOverflowSelectList="true" headerMode="Inline" upperCase="false"
						expanded="true" expandable="false" applyContentPadding="false" class="dtd-icon-tab-no-margin dtd-icon-tab-no-border-bottom"
						items="{ path: 'ZSSD_ONELOOK_MDATA_SRV>/ZSSD_OL_STATUS_TABSet', filters: [{path: 'ApplicationId', operator: 'EQ', value1: 'R'}]}">
						<items>
							<IconTabFilter text="{ZSSD_ONELOOK_MDATA_SRV>StatusTabDesc}" key="{ZSSD_ONELOOK_MDATA_SRV>StatusTab}"/>
						</items>
					</IconTabBar>
				</f:content>
			</f:DynamicPageHeader>
		</f:header>
		<f:content>
			<VBox>
				<smartTable:SmartTable id="idSmartTableReport" entitySet="OLHeaderSet" smartFilterId="smartFilterBar" tableType="ResponsiveTable"
					useExportToExcel="false" useVariantManagement="false" useTablePersonalisation="false" header="Line Items" showRowCount="true"
					persistencyKey="OneLook_Request_Report" enableAutoBinding="true" editTogglable="false" beforeRebindTable="onBeforeRebindTable"
					initiallyVisibleFields="TransTypeDesc,Status,DaysElapsed,BssCase,Sto,DeliveryOrder" demandPopin="true"
					requestAtLeastFields="TransTypeDesc,Status,DaysElapsed,BssCase,Sto,DeliveryOrder,StatusId">
					<!--layout data used to make the table growing but the filter bar fixed -->
					<smartTable:layoutData>
						<FlexItemData growFactor="1" baseSize="0%"/>
					</smartTable:layoutData>
					<Table growing="true" growingThreshold="20">
						<columns>
							<Column width="17%">
								<customData>
									<core:CustomData key="p13nData" value='\{"columnKey": "RefNo,DateSubmitted", "leadingProperty": "RefNo,DateSubmitted", "columnIndex": 0}'/>
								</customData>
								<Text text="{i18n>ReferenceNo2}"></Text>
							</Column>
						</columns>
						<items>
							<ColumnListItem>
								<ObjectIdentifier titleActive="true" title="{RefNo}"
									text="{path: 'DateSubmitted', type:'sap.ui.model.type.Date', formatOptions:{pattern: 'MMM dd, yyyy', UTC: true, strictParsing: true}}"
									titlePress="onPressDTDRequest" app:StatusId="{StatusId}"/>
							</ColumnListItem>
						</items>
					</Table>
				</smartTable:SmartTable>
